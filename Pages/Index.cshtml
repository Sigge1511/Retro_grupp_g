@page
@model IndexModel
@{
    ViewData["Title"] = "Startsida";
}



<header class="rt-header dashboard">
    <img src="/images/RetroLogo.png" alt="RetroTapes VHS Rentals" class="rt-logo" />
    <div class="rt-user">Inloggad som: <strong>@Model.StaffName</strong></div>
</header>



<main class="dashboard">


        <!-- 3 x 2 stora rutor -->
        <section class="grid-big">
            <a asp-page="/Rentals/CreateRental" class="tile tile--green">Hyr</a>
            <a asp-page="/Rentals/Return" class="tile tile--orange">Åter</a>
            <a asp-page="/Rentals/FindFilmToRent" class="tile tile--cream">Sök</a>

            <a asp-page="/Customers/Index" class="tile tile--cream">Kund</a>

            <a asp-page="/Films/Index" class="tile tile--cream">Film</a>

            <a asp-page="/Rentals/Return" class="tile tile--peach"><span>Ersättnings</span><span>avgift</span></a>

        </section>

        <!-- Nederkant: rund INSPO + tre små knappar -->
        <section class="bottom-row">


            <a asp-page="/TopLists" class="inspo">Inspo</a>

            <div class="small-actions">

                <a asp-page="/Help" class="small">Hjälp</a>
            </div>

    </section>
</main>



<style>
    :root {
        --bg: #f2e2ca;
        --text: #231f20;
        --green: #b9d3a8;
        --orange: #f4b76c;
        --cream: #eee7df;
        --peach: #e6b69f;
        --small: #e9dfd3;
    }

    html, body {
        height: 100%
    }

    body {
        background: var(--bg);
        color: var(--text);
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif;
    }

    /* Header */
    .rt-header {
        display: flex;
        align-items: center;
        gap: 24px;
        margin: 18px 10px 8px;
    }

    .rt-logo {
        height: 150px;
        width: auto;
        object-fit: contain
    }

    .rt-user {
        font-size: 18px
    }

    /* Dold H1 (finns för tillgänglighet/SEO) */
    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0,0,0,0);
        border: 0;
    }

    /* Layout-ramar */
    .dashboard {
        max-width: 820px;
        margin: 0 auto;
        padding: 10px
    }

    .grid-big {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
    }

    /* Stora rutor */
    .tile {
        display: grid;
        place-items: center;
        text-decoration: none;
        text-transform: uppercase;
        font-size: 34px;
        letter-spacing: .5px;
        border-radius: 6px;
        padding: 38px 10px;
        box-shadow: 0 2px 0 rgba(0,0,0,.08);
        transition: transform .06s ease, box-shadow .06s ease, opacity .15s ease;
        color: var(--text);
    }

        .tile span {
            display: block;
            line-height: 1.05
        }

    .tile--green {
        background: var(--green)
    }

    .tile--orange {
        background: var(--orange)
    }

    .tile--cream {
        background: var(--cream)
    }

    .tile--peach {
        background: var(--peach)
    }

    .tile:focus,
    .tile:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 14px rgba(0,0,0,.08)
    }

    /* Nedersta raden */
    .bottom-row {
        display: flex;
        align-items: center;
        gap: 30px;
        margin-top: 28px;
    }

    .inspo {
        display: grid;
        place-items: center;
        width: 110px;
        height: 110px;
        border-radius: 50%;
        text-decoration: none;
        text-transform: uppercase;
        background: var(--orange);
        color: var(--text);
        box-shadow: 0 2px 0 rgba(0,0,0,.08);
        font-weight: 600;
        letter-spacing: .5px;
    }

        .inspo:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 14px rgba(0,0,0,.08)
        }

    .small-actions {
        display: flex;
        gap: 18px;
        flex: 1;
    }

    .small {
        display: inline-grid;
        place-items: center;
        min-width: 170px;
        padding: 16px 18px;
        border-radius: 6px;
        background: var(--small);
        color: var(--text);
        text-decoration: none;
        text-transform: uppercase;
        font-size: 14px;
        letter-spacing: .7px;
        box-shadow: 0 2px 0 rgba(0,0,0,.08);
    }

        .small:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 14px rgba(0,0,0,.08)
        }

    /* 3 → 2 kolumner */
    @@media (max-width: 992px) {
        .grid-big {
            grid-template-columns: repeat(2, 1fr);
        }
    }


    @@media (max-width: 768px) {
        .rt-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 12px;
        }

        .rt-logo {
            height: 100px;
        }

        .bottom-row {
            flex-direction: column;
            align-items: stretch;
            gap: 18px;
        }

        .small-actions {
            flex-direction: column;
        }
    }

    /* 2 → 1 kolumn + knappar i helbredd */
    @@media (max-width: 600px) {
        .grid-big {
            grid-template-columns: 1fr;
        }

        .small {
            width: 100%;
            max-width: 100%;
            min-width: 0;
        }
    }

    /* Skala typografi/padding i tiles */
    .tile {
        font-size: clamp(18px, 4.5vw, 34px);
        padding: clamp(18px, 6vw, 38px) 10px;
    }


    /* --- Större layout på stora skärmar --- */


    /* Skala upp på breda skärmar */
    @@media (min-width: 1600px) {
        .dashboard {
            max-width: 1200px;
        }

        .grid-big {
            gap: 30px;
        }

        .tile {
            font-size: clamp(18px, 2.2vw, 40px);
            padding: clamp(18px, 5vw, 56px) 10px;
        }

        .rt-logo {
            height: 180px;
        }

        .inspo {
            width: 140px;
            height: 140px;
        }

        .small {
            min-width: 220px;
        }
    }
</style>




