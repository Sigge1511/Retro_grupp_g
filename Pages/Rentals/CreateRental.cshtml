@page
@model Retro_grupp_g.Pages.CreateRentalModel
@{
	ViewData["Title"] = "Hyra film";

}
<h1>Hyra Film</h1>

@if (!ViewData.ModelState.IsValid)
{
    <div class="error-message">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <p>@error.ErrorMessage</p>
        }
    </div>
}

@if (TempData["Success"] != null)
{
    <p style="color: green;">@TempData["Success"]</p>
}

<br>
<form method="get">
	<div>
		<label for="SearchTitle" class="form-label">Filmtitel:</label>
		<input type="text" name="SearchTitle" value="@Model.SearchTitle"/>
	</div>
    <br>
    <div>
        <label for="SearchActor" class="form-label">Skådespelare:</label>
        <input type="text" name="SearchActor" value="@Model.SearchActor" />
    </div>      
    <br>
    <div>
        <label for="SearchGenre" class="form-label">Genre:</label>
        <input type="text" name="SearchGenre" value="@Model.SearchGenre" />
    </div>
    <br>
    <button type="submit" class="btn btn-primary">Sök</button>
</form>

<hr />

@if (Model.Filmer.Any())
{
    <div class="table-content">
        <table class="table">
            <thead>
                <tr>
                    <th>Titel</th>
                    <th>Beskrivning</th>
                    <th>Genre</th>
                    <th>Skådespelare</th>
                    <th>Tillgänglig</th>
                    <th>Hyr ut</th>
                    <th>Återlämna</th>
                </tr>
            </thead>        
            <tbody>
                @foreach (var film in Model.Filmer)
                {
                    <tr>
                        <td>@film.Title</td>
                        <td>@film.Description</td>
                        <td>@string.Join(", ", film.Genres)</td>
                        <td>@film.ActorSummary</td>
                        <td>
                            @(Model.IsAvailable(film.FilmId) ? "Ja" : "Nej")
                        </td>
                        <td>
                            @if (Model.IsAvailable(film.FilmId))
                            {
                                <form method="post" asp-page-handler="Rent">
                                    <input type="hidden" name="FilmId" value="@film.FilmId" />
                                    <select name="SelectedCustomerId" class="form-control" required>
                                        <option value="">Välj kund</option>
                                            @foreach (var customer in Model.Customers)
                                            {
                                                    <option value="@customer.CustomerId">@customer.Name</option>
                                            }
                                    </select>
                                    <select name="SelectedStaffId" class="form-control" required>
                                        <option value="">Välj personal</option>
                                            @foreach (var staff in Model.StaffMembers)
                                            {
                                                    <option value="@staff.StaffId">@staff.Name</option>
                                            }
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-outline-primary">Hyra</button>
                                </form>
                            }
                            </td>
                        <td>
                        @if (!Model.IsAvailable(film.FilmId))
                        {
                            <form method="post" asp-page-handler="Return">
                                <input type="hidden" name="FilmId" value="@film.FilmId" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary">Återlämna</button>
                            </form>
                        }
                        </td>
                    </tr>
                }
            </tbody>
        </table>    
    </div>
}
else
{
    <p>Inga filmer matchar din sökning.</p>
}