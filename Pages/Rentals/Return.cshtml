@page
@model Retro_grupp_g.Pages.Rentals.ReturnModel
@{
    var films = (List<(int InventoryId, int FilmId, string Title)>)ViewData["Films"];
    var customers = (List<(int CustomerId, string FullName, string Email)>)ViewData["Customers"];
}

<h2>Returnera film</h2>
@if (TempData["Msg"] is string msg)
{
    <div id="serverMsg" class="alert alert-info">@msg</div>
}

<form method="post" id="returnForm">
    <!-- Kund -->
    <div class="mb-3">
        <label for="customerSearch" class="form-label">Kund</label>
        <input type="text" class="form-control" list="customersList"
               id="customerSearch" placeholder="Skriv kundnamn eller e-post..." autocomplete="off" />
        <div class="invalid-feedback" id="customerError">Välj en kund från listan.</div>

        <datalist id="customersList">
            @foreach (var c in customers)
            {
                <option value="@c.FullName (@c.Email)" data-id="@c.CustomerId"></option>
            }
        </datalist>
        <input type="hidden" asp-for="SelectedCustomerId" id="SelectedCustomerId" />
    </div>

    <!-- Film -->
    <div class="mb-3">
        <label for="filmSearch" class="form-label">Film (Inventory)</label>
        <input type="text" class="form-control" list="filmsList"
               id="filmSearch" placeholder="Skriv titel..." autocomplete="off" />
        <div class="invalid-feedback" id="filmError">Välj en film från listan.</div>

        <datalist id="filmsList">
            @foreach (var f in films)
            {
                <option value="@f.Title (InvId: @f.InventoryId)" data-id="@f.InventoryId"></option>
            }
        </datalist>
        <input type="hidden" asp-for="SelectedInventoryId" id="SelectedInventoryId" />
    </div>

    <!-- Hint -->
    <div id="previewHint" class="alert" style="display:none" role="alert"></div>

    <!-- Knappar -->
    <button id="btnNormal" class="btn btn-primary me-2" asp-page-handler="ReturnNormal">Registrera retur</button>
    <button id="btnLate" class="btn btn-warning me-2" asp-page-handler="ReturnLate">Sen retur</button>
    <button id="btnDamaged" class="btn btn-danger" asp-page-handler="ReturnDamaged">Skadad</button>
</form>

<script>
    (() => {
      const form       = document.getElementById('returnForm');
      const custInput  = document.getElementById('customerSearch');
      const filmInput  = document.getElementById('filmSearch');
      const custHidden = document.getElementById('SelectedCustomerId');
      const filmHidden = document.getElementById('SelectedInventoryId');
      const hint       = document.getElementById('previewHint');
      const btnN       = document.getElementById('btnNormal');
      const btnL       = document.getElementById('btnLate');
      const serverMsg  = document.getElementById('serverMsg');

      function clearServerMsg(){
        if (serverMsg) serverMsg.style.display = 'none';
      }
      function resetHint(){
        hint.style.display = 'none';
        hint.className = 'alert';
        hint.textContent = '';
        btnN.classList.remove('btn-outline-success'); btnN.classList.add('btn-primary');
        btnL.classList.remove('btn-outline-warning'); btnL.classList.add('btn-warning');
      }

      function setInvalid(inputEl, errorId, on) {
        const err = document.getElementById(errorId);
        if (on) { inputEl.classList.add('is-invalid'); if (err) err.style.display = 'block'; }
        else    { inputEl.classList.remove('is-invalid'); if (err) err.style.display = 'none'; }
      }

      function resolveIdFromList(listId, displayText){
        const list = document.getElementById(listId);
        const opt = Array.from(list.options).find(o => o.value === displayText.trim());
        return opt?.dataset?.id || "";
      }

      function updateHidden(inputEl, listId, hiddenEl, errorId){
        const id = resolveIdFromList(listId, inputEl.value);
        hiddenEl.value = id;
        if (id) setInvalid(inputEl, errorId, false);
        clearServerMsg();  // dölj äldre TempData-meddelande
        resetHint();       // nolla visuell hint innan ny fetch
        refreshPreview();
      }

      async function refreshPreview(){
        const customerId  = custHidden.value;
        const inventoryId = filmHidden.value;

        if (!customerId || !inventoryId){
          resetHint();
          return;
        }

        const url = `?handler=ReturnPreview&customerId=${encodeURIComponent(customerId)}&inventoryId=${encodeURIComponent(inventoryId)}`;

        try {
          const res = await fetch(url, { headers: { 'Accept': 'application/json' }});
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
          const data = await res.json();

          if (!data.found) {
            resetHint();
            return;
          }

          if (data.isLate) {
            hint.className = 'alert alert-warning';
            hint.textContent = `Försenad ${data.daysLate} dag(ar). Förfallodag: ${data.dueDate}.`;
            hint.style.display = 'block';
            btnL.classList.remove('btn-warning'); btnL.classList.add('btn-outline-warning');
            btnN.classList.remove('btn-outline-success'); btnN.classList.add('btn-primary');
          } else {
            hint.className = 'alert alert-success';
            hint.textContent = `I tid. Förfallodag: ${data.dueDate}.`;
            hint.style.display = 'block';
            btnN.classList.remove('btn-primary'); btnN.classList.add('btn-outline-success');
            btnL.classList.remove('btn-outline-warning'); btnL.classList.add('btn-warning');
          }
        } catch {
          resetHint();
        }
      }

      // Wire-up
      custInput.addEventListener('input',  () => updateHidden(custInput, 'customersList', custHidden, 'customerError'));
      custInput.addEventListener('change', () => updateHidden(custInput, 'customersList', custHidden, 'customerError'));
      filmInput.addEventListener('input',  () => updateHidden(filmInput,  'filmsList',     filmHidden, 'filmError'));
      filmInput.addEventListener('change', () => updateHidden(filmInput,  'filmsList',     filmHidden, 'filmError'));

      // Validering på submit
      form.addEventListener('submit', (e) => {
        let ok = true;
        if (!custHidden.value) { setInvalid(custInput, 'customerError', true); ok = false; }
        if (!filmHidden.value) { setInvalid(filmInput,  'filmError',    true); ok = false; }
        if (!ok) e.preventDefault();
      });

      // Init
      resetHint();
    })();
</script>
