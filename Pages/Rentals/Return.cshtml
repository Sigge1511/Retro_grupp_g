@page
@model Retro_grupp_g.Pages.Rentals.ReturnModel
@{
    var films = (List<(int InventoryId, int FilmId, string Title)>)ViewData["Films"];
    var customers = (List<(int CustomerId, string FullName, string Email)>)ViewData["Customers"];
}

<h2>Returnera film</h2>
@if (TempData["Msg"] is string msg)
{
    <div class="alert alert-success">@msg</div>
}

<form method="post">
    <!-- Kund -->
    <div class="mb-3">
        <label for="customerSearch" class="form-label">Kund</label>
        <input type="text" class="form-control js-datalist" list="customersList"
               id="customerSearch" placeholder="Skriv kundnamn eller e-post..." autocomplete="off" />
        <div class="invalid-feedback" id="customerError">Välj en kund från listan.</div>

        <datalist id="customersList">
            @foreach (var c in customers)
            {
                <option value="@c.FullName (@c.Email)" data-id="@c.CustomerId"></option>
            }
        </datalist>
        <input type="hidden" asp-for="SelectedCustomerId" id="SelectedCustomerId" />
    </div>

    <!-- Film -->
    <div class="mb-3">
        <label for="filmSearch" class="form-label">Film (Inventory)</label>
        <input type="text" class="form-control js-datalist" list="filmsList"
               id="filmSearch" placeholder="Skriv titel..." autocomplete="off" />
        <div class="invalid-feedback" id="filmError">Välj en film från listan.</div>

        <datalist id="filmsList">
            @foreach (var f in films)
            {
                <!-- visa InvId i texten för att undvika dubletter -->
                <option value="@f.Title (InvId: @f.InventoryId)" data-id="@f.InventoryId"></option>
            }
        </datalist>
        <input type="hidden" asp-for="SelectedInventoryId" id="SelectedInventoryId" />
    </div>

    <button class="btn btn-primary me-2" asp-page-handler="ReturnNormal">Registrera retur</button>
    <button class="btn btn-warning me-2" asp-page-handler="ReturnLate">Sen retur</button>
    <button class="btn btn-danger" asp-page-handler="ReturnDamaged">Skadad</button>
</form>

@section Scripts {
    <script>
        (function(){
          function wire(inputId, listId, hiddenId, errorId){
            const input  = document.getElementById(inputId);
            const list   = document.getElementById(listId);
            const hidden = document.getElementById(hiddenId);
            const error  = document.getElementById(errorId);
            const opts   = Array.from(list.options);

            function updateHidden(){
              const val = input.value.trim();
              const match = opts.find(o => o.value === val); // exakt match → sätt ID
              if (match){
                hidden.value = match.dataset.id || "";
                input.classList.remove("is-invalid");
                if (error) error.style.display = "none";
              } else {
                hidden.value = "";
              }
            }

            input.addEventListener('input', updateHidden);
            input.addEventListener('change', updateHidden);
          }

          wire('customerSearch', 'customersList', 'SelectedCustomerId', 'customerError');
          wire('filmSearch',      'filmsList',     'SelectedInventoryId', 'filmError');

          // enkel validering vid submit
          document.querySelector('form').addEventListener('submit', function(e){
            let ok = true;
            const custHidden = document.getElementById('SelectedCustomerId');
            const filmHidden = document.getElementById('SelectedInventoryId');
            const custInput  = document.getElementById('customerSearch');
            const filmInput  = document.getElementById('filmSearch');

            if (!custHidden.value){
              ok = false;
              custInput.classList.add('is-invalid');
              document.getElementById('customerError').style.display = 'block';
            }
            if (!filmHidden.value){
              ok = false;
              filmInput.classList.add('is-invalid');
              document.getElementById('filmError').style.display = 'block';
            }
            if (!ok) e.preventDefault();
          });
        })();
    </script>
}