@page
@model Retro_grupp_g.Pages.Films.IndexModel

@{
    ViewData["Title"] = "Index";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<h1>Filmer i databasen</h1>
<div class="content">
    <br>
    <h3>
        <a asp-page="Create" class="normal-link">Klicka här för att lägga till en ny film</a>
    </h3>
    <br>

    <div class="table-content">
        <table class="table">
            <colgroup>
                <col class="c-title">
                <col class="c-desc">
                <col class="c-year">
                <col class="c-days">
                <col class="c-rate">
                <col class="c-len">
                <col class="c-repl">
                <col class="c-rating">
                <col class="c-extra">
                <col class="c-upd">
                <col class="c-lang">
                <col class="c-actions"> <!-- NY -->
            </colgroup>
            <thead>
                <tr>
                    <th>
                        Titel:
                    </th>
                    <th>
                        Beskrivning:
                    </th>
                    <th>
                        Premiär år:
                    </th>
                    <th>
                        Antal dagar tillåtet att hyra:
                    </th>
                    <th>
                        Kostnad per dag:
                    </th>
                    <th>
                        Längd, i minuter:
                    </th>
                    <th>
                        Kostnad för att ersätta:
                    </th>
                    <th>
                        Åldersgräns:
                    </th>
                    <th>
                        Extramaterial:
                    </th>
                    <th>
                        Senast uppdaterad:
                    </th>
                    <th>
                        Språk:
                    </th>
                    <th>Ändra:</th>
                </tr>
            </thead>
            <tbody>
        @foreach (var item in Model.Film) {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Title)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Description)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.ReleaseYear)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.RentalDuration)
                    </td>
                    <td>
                        $ @Html.DisplayFor(modelItem => item.RentalRate)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Length) minuter
                    </td>
                    <td>
                        $ @Html.DisplayFor(modelItem => item.ReplacementCost)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Rating)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.SpecialFeatures)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.LastUpdate)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Language.Name)
                    </td>            
                    <td>
                        <a asp-page="./Edit" asp-route-id="@item.FilmId" class="small-link">Edit</a> 
                            <a asp-page="./Details" asp-route-id="@item.FilmId" class="small-link">Details</a> 
                            <a asp-page="./Delete" asp-route-id="@item.FilmId" class="small-link">Delete</a>
                    </td>
                </tr>
        }
            </tbody>
        </table>
    </div>
</div>