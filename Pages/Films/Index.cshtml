@page
@model Retro_grupp_g.Pages.Films.IndexModel

@{
    ViewData["Title"] = "Index";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Film[0].Title)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Film[0].Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Film[0].ReleaseYear)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Film[0].RentalDuration)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Film[0].RentalRate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Film[0].Length)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Film[0].ReplacementCost)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Film[0].Rating)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Film[0].SpecialFeatures)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Film[0].LastUpdateTemp)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Film[0].Language)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Film[0].OriginalLanguage)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Film) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Title)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ReleaseYear)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.RentalDuration)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.RentalRate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Length)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ReplacementCost)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Rating)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.SpecialFeatures)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LastUpdateTemp)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Language.LanguageId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.OriginalLanguage.LanguageId)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.FilmId">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.FilmId">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.FilmId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
